# Cloudflare Pages headers — enforce the privacy posture at the edge.
# connect-src 'self' = the page may only talk to its own origin (parsers.js etc),
# never a third party. No upload endpoint exists. This is the "nothing leaves" guarantee.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; base-uri 'none'; form-action 'none'; object-src 'none'; frame-ancestors 'none'
  Referrer-Policy: no-referrer
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), camera=(), microphone=()
